<odoo>
    <template id="mail_notification_light_branding" inherit_id="mail.mail_notification_light">
        <xpath expr="//tr[td[contains(normalize-space(.), 'Powered by')]]/td/a[contains(@href, 'odoo.com')]" position="replace">
            <a target="_blank"
               href="https://dreamwarez.in"
               t-att-style="'color: ' + (company.email_secondary_color or '#875A7B') + ';'">Dreamwarez</a>
        </xpath>
    </template>

    <template id="mail_notification_layout_branding" inherit_id="mail.mail_notification_layout">
        <xpath expr="//div[contains(normalize-space(.), 'Powered by')]/a[contains(@href, 'odoo.com')]" position="replace">
            <a target="_blank"
               href="https://dreamwarez.in"
               t-att-style="'color: ' + (company.email_secondary_color or '#875A7B') + ';'">Dreamwarez</a>
        </xpath>
    </template>
</odoo>
